        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam componentStyle uml2\nskinparam backgroundColor #FFFFFF\nskinparam packageBackgroundColor white\n\ntitle SƠ ĐỒ KIẾN TRÚC &amp; TẤT CẢ CHỨC NĂNG HỆ THỐNG QUẢN LÝ ĐẶT LỊCH KHÁM BỆNH\n\n&#39; 1. CLIENT LAYER\npackage \&quot;1. CLIENT LAYER (Giao diện người dùng)\&quot; #E1F5FE {\n  package \&quot;Phân hệ Bệnh nhân (Patient)\&quot; #B3E5FC {\n    [Đăng ký / Đăng nhập &amp; Auth] as AuthUI\n    [Xem &amp; Cập nhật Hồ sơ/Bệnh án] as ProfileUI\n    [Tra cứu, Lọc &amp; Tìm Bác sĩ] as SearchDocUI\n    [Đặt lịch khám &amp; Điền triệu chứng] as BookingUI\n    [Xem lịch sử &amp; Hủy lịch hẹn] as CancelUI\n  }\n  \n  package \&quot;Phân hệ Bác sĩ (Doctor)\&quot; #E1BEE7 {\n    [Đăng ký / Quản lý Ca làm việc (Schedules)] as DoctorScheduleUI\n    [Xem danh sách Bệnh nhân đặt khám] as DoctorApptUI\n    [Cập nhật trạng thái ca khám &amp; Chẩn đoán] as DoctorNoteUI\n  }\n  \n  package \&quot;Phân hệ Quản trị viên (Admin)\&quot; #FFCDD2 {\n    [Quản lý Bác sĩ &amp; Bệnh nhân (CRUD)] as AdminUserUI\n    [Quản lý Chuyên khoa &amp; Dịch vụ (Master Data)] as AdminCategoryUI\n    [Thống kê &amp; Báo cáo Doanh thu/Ca khám] as AdminReportUI\n  }\n}\n\n&#39; 2. SECURITY LAYER\npackage \&quot;2. SECURITY LAYER (Bảo mật &amp; Phân quyền)\&quot; #FFF3E0 {\n  [JwtTokenFilter (Xác thực Token)] as JWTFilter\n  [Role-Based Authorization (PATIENT / DOCTOR / ADMIN)] as RoleGuard\n  [Input Validation (@Valid DTO)] as Validator\n}\n\n&#39; 3. CONTROLLER LAYER\npackage \&quot;3. CONTROLLER LAYER (RESTful Endpoints)\&quot; #F3E5F5 {\n  [AuthController\\n/api/v1/auth] as AuthCtrl\n  [PatientController\\n/api/v1/patients] as PatientCtrl\n  [DoctorController\\n/api/v1/doctors] as DoctorCtrl\n  [BookingController\\n/api/v1/appointments] as BookingCtrl\n  [AdminController\\n/api/v1/admin] as AdminCtrl\n}\n\n&#39; 4. SERVICE LAYER\npackage \&quot;4. SERVICE LAYER (Nghiệp vụ cốt lõi &amp; Tối ưu)\&quot; #E8F5E9 {\n  [AuthService\\n(Đăng ký, Hash Password, Tạo JWT)] as AuthService\n  [PatientService\\n(Quản lý hồ sơ, Bệnh án)] as PatientService\n  [DoctorScheduleService\\n(Tạo/Bật/Tắt Slot khám)] as ScheduleService\n  \n  package \&quot;Booking Processing Engine\&quot; #C8E6C9 {\n    [BookingServiceImpl\\n(Xử lý Đặt/Hủy lịch, Khóa tranh chấp)] as BookingService\n    [Locking Mechanism\\n(Pessimistic Lock: SELECT FOR UPDATE)] as LockEngine\n  }\n  \n  [AdminManagementService\\n(Phê duyệt Bác sĩ, CRUD, Báo cáo)] as AdminService\n  \n  &#39; Advanced Async &amp; Cache Services\n  [Redis Cache Service\\n(Cache danh sách Bác sĩ &amp; Slot rảnh)] as CacheService\n  [Async Email Notification Service\\n(Gửi mail xác nhận đặt lịch &amp; Nhắc lịch)] as EmailService\n}\n\n&#39; 5. REPOSITORY &amp; DATA LAYER\npackage \&quot;5. REPOSITORY &amp; DATA LAYER (Lưu trữ)\&quot; #EFEBE9 {\n  [Spring Data JPA Repositories] as Repositories\n  database \&quot;PostgreSQL / MySQL\\n(Chứa Users, Schedules, Appointments...)\&quot; as MainDB\n  database \&quot;Redis Memory Database\\n(Bộ nhớ đệm Caching)\&quot; as RedisDB\n  queue \&quot;Message Queue / Async Task\\n(Xử lý gửi Email bất đồng bộ)\&quot; as EmailQueue\n}\n\n&#39; KẾT NỐI LUỒNG DỮ LIỆU (DATA FLOWS)\n\n&#39; Client -&gt; Security\nAuthUI --&gt; JWTFilter\nProfileUI --&gt; JWTFilter\nSearchDocUI --&gt; JWTFilter\nBookingUI --&gt; JWTFilter\nCancelUI --&gt; JWTFilter\n\nDoctorScheduleUI --&gt; JWTFilter\nDoctorApptUI --&gt; JWTFilter\nDoctorNoteUI --&gt; JWTFilter\n\nAdminUserUI --&gt; JWTFilter\nAdminCategoryUI --&gt; JWTFilter\nAdminReportUI --&gt; JWTFilter\n\n&#39; Security -&gt; Controllers\nJWTFilter --&gt; RoleGuard\nRoleGuard --&gt; Validator\n\nValidator --&gt; AuthCtrl\nValidator --&gt; PatientCtrl\nValidator --&gt; DoctorCtrl\nValidator --&gt; BookingCtrl\nValidator --&gt; AdminCtrl\n\n&#39; Controllers -&gt; Services\nAuthCtrl --&gt; AuthService\nPatientCtrl --&gt; PatientService\nDoctorCtrl --&gt; ScheduleService\nDoctorCtrl --&gt; BookingService\nBookingCtrl --&gt; BookingService\nAdminCtrl --&gt; AdminService\n\n&#39; Core Business Logic &amp; Advanced Services\nBookingService --&gt; LockEngine\nSearchDocUI ..&gt; CacheService : \&quot;Đọc cache Bác sĩ/Lịch rảnh\&quot;\nCacheService --&gt; RedisDB\n\nBookingService --&gt; EmailService : \&quot;Trigger sự kiện gửi Mail\&quot;\nEmailService --&gt; EmailQueue : \&quot;Đưa Task gửi Mail vào hàng đợi Async\&quot;\n\n&#39; Services -&gt; Repositories &amp; DB\nAuthService --&gt; Repositories\nPatientService --&gt; Repositories\nScheduleService --&gt; Repositories\nBookingService --&gt; Repositories\nAdminService --&gt; Repositories\n\nRepositories --&gt; MainDB\n\n@enduml&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="O6Hi_ihlza0K4yU8gWS_-94">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=10;" vertex="1">
