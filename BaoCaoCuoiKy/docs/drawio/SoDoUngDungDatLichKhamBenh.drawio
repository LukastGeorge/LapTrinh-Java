        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;erDiagram\n\n    USERS {\n        bigint id PK \&quot;Mã tài khoản\&quot;\n        string email UK \&quot;Email đăng nhập\&quot;\n        string password_hash \&quot;Mật khẩu mã hóa (BCrypt)\&quot;\n        string role \&quot;PATIENT, DOCTOR, ADMIN\&quot;\n        boolean is_active \&quot;Trạng thái tài khoản (true/false)\&quot;\n        timestamp created_at \&quot;Thời gian tạo\&quot;\n        timestamp updated_at \&quot;Thời gian cập nhật\&quot;\n    }\n\n    PATIENTS {\n        bigint user_id PK,FK \&quot;Mã bệnh nhân (Liên kết USERS)\&quot;\n        string full_name \&quot;Họ và tên\&quot;\n        date dob \&quot;Ngày sinh\&quot;\n        string gender \&quot;MALE, FEMALE, OTHER\&quot;\n        string phone UK \&quot;Số điện thoại\&quot;\n        string address \&quot;Địa chỉ\&quot;\n        string medical_history \&quot;Tiền sử bệnh án cơ bản\&quot;\n    }\n\n    SPECIALTIES {\n        bigint id PK \&quot;Mã chuyên khoa\&quot;\n        string name \&quot;Tên chuyên khoa (Tim mạch, Nhi...)\&quot;\n        string description \&quot;Mô tả chuyên khoa\&quot;\n    }\n\n    DOCTORS {\n        bigint user_id PK,FK \&quot;Mã bác sĩ (Liên kết USERS)\&quot;\n        bigint specialty_id FK \&quot;Mã chuyên khoa\&quot;\n        string full_name \&quot;Họ và tên bác sĩ\&quot;\n        string phone UK \&quot;Số điện thoại\&quot;\n        string degree \&quot;Bằng cấp / Học vị\&quot;\n        int experience_years \&quot;Số năm kinh nghiệm\&quot;\n        decimal consultation_fee \&quot;Giá khám mặc định\&quot;\n        boolean is_approved \&quot;Xác nhận duyệt bởi Admin\&quot;\n    }\n\n    SCHEDULES {\n        bigint id PK \&quot;Mã ca làm việc\&quot;\n        bigint doctor_id FK \&quot;Mã bác sĩ\&quot;\n        date work_date \&quot;Ngày làm việc\&quot;\n        time start_time \&quot;Giờ bắt đầu slot (VD: 08:00)\&quot;\n        time end_time \&quot;Giờ kết thúc slot (VD: 08:30)\&quot;\n        boolean is_available \&quot;Trạng thái trống (true=còn trống)\&quot;\n    }\n\n    APPOINTMENTS {\n        bigint id PK \&quot;Mã lịch hẹn\&quot;\n        string booking_code UK \&quot;Mã đặt chỗ (UUID/Random string)\&quot;\n        bigint patient_id FK \&quot;Mã bệnh nhân\&quot;\n        bigint doctor_id FK \&quot;Mã bác sĩ\&quot;\n        bigint schedule_id FK \&quot;Mã khung giờ khám\&quot;\n        string symptoms \&quot;Triệu chứng ban đầu / Lý do khám\&quot;\n        string status \&quot;CONFIRMED, COMPLETED, CANCELLED\&quot;\n        decimal price \&quot;Giá khám thực tế tại thời điểm đặt\&quot;\n        timestamp created_at \&quot;Thời gian tạo lịch hẹn\&quot;\n    }\n\n    MEDICAL_RECORDS {\n        bigint id PK \&quot;Mã hồ sơ khám\&quot;\n        bigint appointment_id FK,UK \&quot;Mã lịch hẹn tương ứng\&quot;\n        string diagnosis \&quot;Chẩn đoán bệnh\&quot;\n        string doctor_notes \&quot;Ghi chú bác sĩ\&quot;\n        timestamp created_at \&quot;Thời gian tạo ghi chú\&quot;\n    }\n\n    %% Thiết lập mối quan hệ (Relationships)\n    USERS ||--o| PATIENTS : \&quot;là (1-1)\&quot;\n    USERS ||--o| DOCTOR : \&quot;là (1-1)\&quot;\n    SPECIALTIES ||--o{ DOCTOR : \&quot;thuộc về (1-N)\&quot;\n    DOCTOR ||--o{ SCHEDULES : \&quot;đăng ký (1-N)\&quot;\n    PATIENTS ||--o{ APPOINTMENTS : \&quot;đặt (1-N)\&quot;\n    DOCTOR ||--o{ APPOINTMENTS : \&quot;phụ trách (1-N)\&quot;\n    SCHEDULES ||--o| APPOINTMENTS : \&quot;áp dụng cho (1-1)\&quot;\n    APPOINTMENTS ||--o| MEDICAL_RECORDS : \&quot;có kết quả (1-1)\&quot;&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="O6Hi_ihlza0K4yU8gWS_-874">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=10;" vertex="1">
            <mxGeometry as="geometry" />
          </mxCell>
        </UserObject>
